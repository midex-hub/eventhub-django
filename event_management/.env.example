# Django Settings
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
SITE_URL=http://localhost:8000

# Database (MySQL)
DB_NAME=event_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# Paystack (required for payments)
PAYSTACK_PUBLIC_KEY=pk_live_or_test_xxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_or_test_xxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxx



# Email (optional - defaults to mailhog for dev)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=EventHub <noreply@eventhub.com>

# Paystack Base URL
PAYSTACK_BASE_URL=https://api.paystack.co
